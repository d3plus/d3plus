{
  "name": "d3plus",
  "version": "3.0.16",
  "description": "Data visualization made easy. A javascript library that extends the popular D3.js to enable fast and beautiful visualizations.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "homepage": "https://d3plus.org",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git"
  },
  "keywords": [
    "charts",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "docs": "node scripts/docs/docs.js",
    "pretest": "npm run build:esm --workspaces --if-present",
    "release": "node scripts/release.js",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@octokit/rest": "^21.1.1",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-swc": "^0.4.0",
    "@swc/core": "^1.11.7",
    "@types/d3-array": "^3.2.2",
    "@types/d3-brush": "^3.0.6",
    "@types/d3-color": "^3.1.3",
    "@types/d3-fetch": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-format": "^3.0.4",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-interpolate-path": "^2.0.3",
    "@types/d3-polygon": "^3.0.2",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-tile": "^1.0.1",
    "@types/d3-time": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/file-saver": "^2.0.7",
    "@types/topojson-client": "^3.1.5",
    "canvas": "^3.1.0",
    "chokidar": "^4.0.3",
    "eslint": "^9.21.0",
    "jsdom": "^26.0.0",
    "live-server": "^1.2.2",
    "mocha": "^11.1.0",
    "rollup": "^4.34.9",
    "shelljs": "^0.8.4",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "uglify-js": "^3.19.3",
    "yocto-spinner": "^1.1.0"
  }
}
