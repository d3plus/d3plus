{
  "name": "@d3plus/text",
  "version": "3.1.6",
  "description": "A smart SVG text box with line wrapping and automatic font size scaling.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./es/index.js"
    }
  },
  "browser": "./umd/d3plus-text.full.js",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "files": [
    "umd",
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/text"
  },
  "keywords": [
    "text",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "build:umd": "node ../../scripts/build-umd.js",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint index.ts src/**/*.ts && eslint --global=it test && mocha 'test/**/*-test.js'",
    "test:coverage": "c8 -r text -r lcov --src src mocha 'test/**/*-test.js'"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@d3plus/dom": "workspace:*",
    "d3-selection": "^3.0.0",
    "d3-transition": "^3.0.1",
    "hyphenated": "^1.2.0"
  }
}