{
  "name": "@d3plus/vue",
  "version": "4.3.0",
  "description": "Vue 3 components for d3plus visualizations.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./es/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "files": [
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/vue"
  },
  "keywords": [
    "vue",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint index.ts src/**/*.ts && eslint --global=it --global=before test && mocha 'test/**/*-test.js'",
    "test:coverage": "c8 -r text -r lcov --src src mocha 'test/**/*-test.js'"
  },
  "dependencies": {
    "@d3plus/core": "workspace:*",
    "@d3plus/dom": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.2.5",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}