{
  "name": "@d3plus/export",
  "version": "3.0.16",
  "description": "Export methods for transforming and downloading SVG.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.ts",
  "exports": {
    ".": {
      "types": "./types/index.ts",
      "default": "./es/index.js"
    }
  },
  "browser": "./umd/d3plus-export.full.js",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "umd",
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/export"
  },
  "keywords": [
    "export",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "build:umd": "node ../../scripts/build-umd.js",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint index.ts src/**/*.ts && eslint --global=it test && mocha 'test/**/*-test.ts'"
  },
  "dependencies": {
    "file-saver": "1.3.3",
    "html-to-image": "^1.11.11"
  }
}