{
  "name": "@d3plus/svelte",
  "version": "4.2.0",
  "description": "Svelte action for rendering d3plus visualizations.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./es/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "files": [
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/svelte"
  },
  "keywords": [
    "svelte",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint index.ts && eslint --global=it --global=before test && mocha 'test/**/*-test.js'",
    "test:coverage": "c8 -r text -r lcov mocha 'test/**/*-test.js'"
  },
  "dependencies": {
    "@d3plus/dom": "workspace:*"
  },
  "devDependencies": {
    "@d3plus/core": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "svelte": "^5.0.0",
    "vite": "^6.2.5"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  }
}
