{
  "name": "@d3plus/math",
  "version": "4.0.0",
  "description": "Mathematical functions to aid in calculating visualizations.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./es/index.js"
    }
  },
  "browser": "./umd/d3plus-math.full.js",
  "engines": {
    "node": ">=22"
  },
  "sideEffects": false,
  "files": [
    "umd",
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/math"
  },
  "keywords": [
    "math",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "build:umd": "node ../../scripts/build-umd.js",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint index.ts src/**/*.ts && eslint --global=it test && mocha 'test/**/*-test.js'",
    "test:coverage": "c8 -r text -r lcov --src src mocha 'test/**/*-test.js'"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-polygon": "^3.0.1"
  }
}