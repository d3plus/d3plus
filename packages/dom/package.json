  },
  "keywords": [
    "dom",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "build:umd": "node ../../scripts/build-umd.js",
