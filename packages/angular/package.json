{
  "name": "@d3plus/angular",
  "version": "4.3.0",
  "description": "Angular components for d3plus visualizations.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/angular"
  },
  "keywords": [
    "angular",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build:esm": "ng-packagr -p ng-package.json",
    "build": "ng-packagr -p ng-package.json",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint src/**/*.ts && eslint --global=it --global=before test && mocha 'test/**/*-test.js'"
  },
  "dependencies": {
    "@d3plus/core": "workspace:*",
    "@d3plus/dom": "workspace:*",
    "tslib": "^2.6.0"
  },
  "peerDependencies": {
    "@angular/common": ">=20.0.0",
    "@angular/core": ">=20.0.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6.3",
    "@angular/build": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "ng-packagr": "^21.0.0",
    "rxjs": "^7.8.0",
    "vite": "^6.2.5",
    "zone.js": "^0.15.0"
  }
}