{
  "name": "@d3plus/render",
  "version": "4.0.0",
  "description": "A backend-agnostic scene graph and pluggable SVG/Canvas renderers for d3plus visualizations.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./es/index.js"
    }
  },
  "browser": "./umd/d3plus-render.full.js",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "files": [
    "umd",
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/render"
  },
  "keywords": [
    "canvas",
    "svg",
    "render",
    "scene-graph",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "build:umd": "node ../../scripts/build-umd.js",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint index.ts src/**/*.ts && eslint --global=it test && mocha 'test/**/*-test.js'",
    "test:coverage": "c8 -r text -r lcov --src src mocha 'test/**/*-test.js'"
  },
  "dependencies": {
    "@d3plus/data": "workspace:*",
    "d3-color": "^3.1.0",
    "d3-interpolate": "^3.0.1",
    "d3-interpolate-path": "^2.3.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1",
    "textures": "^1.2.3"
  }
}