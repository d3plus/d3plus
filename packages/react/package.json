{
  "name": "@d3plus/react",
  "version": "3.0.16",
  "description": "React components for d3plus visualizations.",
  "license": "MIT",
  "type": "module",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./es/index.jsx"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "files": [
    "es",
    "types"
  ],
  "homepage": "https://d3plus.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3plus/d3plus.git",
    "directory": "packages/react"
  },
  "keywords": [
    "react",
    "d3",
    "d3plus",
    "data",
    "visualization"
  ],
  "scripts": {
    "build:esm": "node ../../scripts/build-esm.js",
    "build:types": "tsc",
    "dev": "node ../../scripts/dev.js",
    "test": "eslint && mocha --import=./test/loader.mjs 'test/**/*-test.mjs'"
  },
  "dependencies": {
    "@d3plus/core": "workspace:*",
    "@d3plus/dom": "workspace:*"
  },
  "devDependencies": {
    "@d3plus/color": "workspace:*",
    "@mantine/core": "^7.8.1",
    "@mantine/hooks": "^7.8.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint-plugin-react": "^7.37.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.5"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  }
}