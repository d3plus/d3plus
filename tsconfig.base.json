{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "es", "dev", "test", "types"]
}
